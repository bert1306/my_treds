# База данных (SQLite). В продакшене укажите путь к файлу БД.
DATABASE_URL="file:./dev.db"

# URL приложения (для писем восстановления пароля и редиректов)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ollama (для чата по пространству и перевода по ссылкам). Не обязательно на хостинге.
OLLAMA_URL="http://localhost:11434"
# На VPS с 2 ГБ RAM используйте llama3.2:1b; с 4+ ГБ — llama3.2
OLLAMA_MODEL="llama3.2"

# Макс. число одновременных фоновых запросов чата (долгие >30s уходят в фон). По умолчанию 2.
# CHAT_BACKGROUND_JOBS_MAX=2

# База данных (SQLite). В продакшене укажите путь к файлу БД.
DATABASE_URL="file:./dev.db"

# URL приложения (для писем восстановления пароля и редиректов)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ollama (для чата по треду и перевода по ссылкам). Не обязательно на хостинге.
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

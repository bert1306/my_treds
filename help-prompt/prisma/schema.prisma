generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  deviceId     String?   @unique // один пользователь на устройство (web); позже — привязка по логину
  name         String?   // имя для обращения в диалогах
  email        String?   @unique
  login        String?   // заготовка под логин
  passwordHash String?   // заготовка под пароль (хеш)
  telegram     String?   // telegram username
  role         String?   // роль из мастера (developer, pm, analyst, …); если задана — в мастере не спрашиваем
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel       String         @default("web")
  title         String?        // название диалога (переименовывается пользователем)
  isFavorite    Boolean        @default(false)
  deviceId      String?        // привязка к устройству/сессии в web; позже — telegramId и др.
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      Message[]
  collectedData CollectedData[]
}

model CollectedData {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key       String   // ключ поля (goal, goalDetail, role, detailLevel, context)
  value     String   // значение (текст)
  createdAt DateTime @default(now())
  @@unique([sessionId, key])
  @@index([sessionId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())
}
